---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ===== NAVBAR ===== -->
  <nav class="navbar" id="navbar">
    <div class="container">
      <a href="#" class="logo">LetsK<span>AI</span></a>
      <div class="nav-links" id="navLinks">
        <a href="#services">Services</a>
        <a href="#how-it-works">How It Works</a>
        <a href="#about">About</a>
        <a href="#cta" class="btn btn-primary nav-cta">Book a Free Call</a>
      </div>
      <button class="mobile-toggle" id="mobileToggle" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">&#9889; AI Automation for Small Business</div>
        <h1>
          Stop Doing Work a Machine
          <span class="highlight">Could Handle</span>
        </h1>
        <p>
          We help small businesses automate repetitive tasks, streamline operations,
          and get time back — using practical AI tools, not hype.
        </p>
        <div class="hero-buttons">
          <a href="#cta" class="btn btn-primary">Book a Free Strategy Call &#8594;</a>
          <a href="#how-it-works" class="btn btn-secondary">See How It Works</a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <strong>10+</strong>
            <span>Hours saved per week</span>
          </div>
          <div class="hero-stat">
            <strong>50+</strong>
            <span>Workflows automated</span>
          </div>
          <div class="hero-stat">
            <strong>3x</strong>
            <span>Faster response times</span>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-card">
          <div class="hero-card-header">
            <div class="hero-card-icon">&#9889;</div>
            <div>
              <div class="hero-card-title">Today's Automations</div>
              <div class="hero-card-sub">Running smoothly</div>
            </div>
          </div>
          <div class="automation-item">
            <div class="check">&#10003;</div>
            <span>Invoice processed &amp; sent</span>
            <span class="time-saved">Saved 25 min</span>
          </div>
          <div class="automation-item">
            <div class="check">&#10003;</div>
            <span>New lead added to CRM</span>
            <span class="time-saved">Saved 10 min</span>
          </div>
          <div class="automation-item">
            <div class="check">&#10003;</div>
            <span>Support ticket triaged</span>
            <span class="time-saved">Saved 15 min</span>
          </div>
          <div class="automation-item">
            <div class="check">&#10003;</div>
            <span>Weekly report generated</span>
            <span class="time-saved">Saved 45 min</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="services" id="services">
    <div class="container">
      <div class="section-header">
        <div class="section-label">What We Do</div>
        <h2 class="section-title">AI Services Built for Small Business</h2>
        <p class="section-subtitle">
          Practical solutions — not science projects. Every service is designed to save
          you time, reduce errors, and let your team focus on what matters.
        </p>
      </div>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">&#129302;</div>
          <h3>AI Chatbots &amp; Assistants</h3>
          <p>Custom chatbots that answer customer questions, qualify leads, and handle routine inquiries — 24/7.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">&#128260;</div>
          <h3>Workflow Automation</h3>
          <p>Connect your tools and eliminate manual steps. Data moves automatically between your apps.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">&#128202;</div>
          <h3>Data &amp; Reporting</h3>
          <p>Automated reports and dashboards that give you visibility without the manual work.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">&#128231;</div>
          <h3>Email &amp; Follow-Up</h3>
          <p>Smart email handling, auto-responses, and follow-up sequences that keep customers engaged.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">&#128197;</div>
          <h3>Scheduling &amp; Booking</h3>
          <p>Automated scheduling that handles confirmations, reminders, and rescheduling without back-and-forth.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">&#128295;</div>
          <h3>Custom Integrations</h3>
          <p>Make your existing tools work together. We connect the apps you already use into a seamless system.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="how-it-works" id="how-it-works">
    <div class="container">
      <div class="section-header">
        <div class="section-label">How It Works</div>
        <h2 class="section-title">From Manual Chaos to Automated Clarity</h2>
        <p class="section-subtitle">
          We don't sell you software and wish you luck. We work with you to find
          what's slowing your business down — then build automations that fix it.
        </p>
      </div>
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>We Audit Your Workflows</h3>
            <p>We look at how your team actually works — the tools, the steps, the bottlenecks. No generic templates.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>We Design the Automation</h3>
            <p>We map out exactly what gets automated, how it connects to your existing tools, and what changes for your team.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>We Build &amp; Launch</h3>
            <p>We build the workflows, test them thoroughly, and deploy them into your business — with training included.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3>We Monitor &amp; Improve</h3>
            <p>Automations aren't set-and-forget. We track performance, fix issues, and optimize over time.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section class="about" id="about">
    <div class="container">
      <div class="about-text">
        <div class="section-label">About LetsK AI</div>
        <h2 class="section-title">We Make AI Work for Small Businesses</h2>
        <p>
          We're not a big agency with generic playbooks. We're a small, focused team
          that helps small businesses use AI to run better — without the jargon,
          the bloated retainers, or the empty promises.
        </p>
        <p>
          We believe AI should be practical, affordable, and easy to understand.
          If it doesn't save you time or money, we won't recommend it.
        </p>
        <div class="about-values">
          <div class="value">
            <span class="value-icon">&#127919;</span>
            <div>
              <strong>Results-First</strong>
              <p>Every automation we build is tied to a measurable outcome.</p>
            </div>
          </div>
          <div class="value">
            <span class="value-icon">&#128483;</span>
            <div>
              <strong>Plain Language</strong>
              <p>No tech jargon, no buzzwords. We explain everything clearly.</p>
            </div>
          </div>
          <div class="value">
            <span class="value-icon">&#129309;</span>
            <div>
              <strong>Built to Last</strong>
              <p>Reliable systems that keep running — not one-off hacks.</p>
            </div>
          </div>
          <div class="value">
            <span class="value-icon">&#128170;</span>
            <div>
              <strong>No Lock-In</strong>
              <p>We train your team to manage what we build. You own it.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="about-quote">
        <blockquote>
          "We approach every project with one question: will this actually make your day easier?"
        </blockquote>
        <cite>— The LetsK AI Team</cite>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta" id="cta">
    <div class="container">
      <h2>Ready to Get Your Time Back?</h2>
      <p>
        Book a free 30-minute strategy call. We'll look at your current workflows,
        identify what can be automated, and give you a clear plan — no obligation.
      </p>
      <a href="https://calendly.com" target="_blank" rel="noopener" class="btn btn-white">
        Book Your Free Call &#8594;
      </a>
      <p class="cta-note">No commitment. No hard sell. Just a conversation about what's possible.</p>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div>
          <a href="#" class="logo">LetsK<span>AI</span></a>
          <p class="tagline">AI automation for small businesses.</p>
        </div>
        <div class="footer-links">
          <a href="#services">Services</a>
          <a href="#how-it-works">How It Works</a>
          <a href="#about">About</a>
          <a href="#cta">Contact</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 LetsK AI. All rights reserved.</span>
        <span>hello@letskai.com</span>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* ===== UTILITIES ===== */
  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 32px;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: #6c63ff;
    color: #fff;
    box-shadow: 0 4px 20px rgba(108, 99, 255, 0.35);
  }

  .btn-primary:hover {
    background: #5a52d5;
    transform: translateY(-2px);
    box-shadow: 0 6px 28px rgba(108, 99, 255, 0.45);
  }

  .btn-secondary {
    background: transparent;
    color: #6c63ff;
    border: 2px solid #6c63ff;
  }

  .btn-secondary:hover {
    background: #6c63ff;
    color: #fff;
  }

  .btn-white {
    background: #fff;
    color: #6c63ff;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.15);
  }

  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #6c63ff;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 16px;
    color: #1a1a2e;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: #555;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 800;
    color: #1a1a2e;
  }

  .logo span {
    color: #6c63ff;
  }

  /* ===== NAVBAR ===== */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 16px 0;
    transition: all 0.3s ease;
  }

  .navbar.scrolled {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
    padding: 12px 0;
  }

  .navbar .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-links a {
    font-size: 0.9rem;
    font-weight: 500;
    color: #555;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: #6c63ff;
  }

  .nav-cta {
    padding: 10px 24px !important;
    font-size: 0.9rem !important;
    border-radius: 10px !important;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px;
  }

  .mobile-toggle span {
    width: 24px;
    height: 2px;
    background: #1a1a2e;
    border-radius: 2px;
    transition: all 0.3s;
  }

  /* ===== HERO ===== */
  .hero {
    padding: 160px 0 100px;
    background: linear-gradient(165deg, #f8f7ff 0%, #eef0ff 40%, #fff 100%);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(108, 99, 255, 0.08) 0%, transparent 70%);
    border-radius: 50%;
  }

  .hero .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(108, 99, 255, 0.08);
    border: 1px solid rgba(108, 99, 255, 0.15);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #6c63ff;
    margin-bottom: 24px;
  }

  .hero h1 {
    font-size: 3.25rem;
    font-weight: 800;
    line-height: 1.12;
    margin-bottom: 24px;
    color: #1a1a2e;
  }

  .highlight {
    background: linear-gradient(135deg, #6c63ff, #9f7aea);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    font-size: 1.15rem;
    color: #555;
    margin-bottom: 36px;
    line-height: 1.7;
    max-width: 480px;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    gap: 40px;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .hero-stat strong {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: #6c63ff;
  }

  .hero-stat span {
    font-size: 0.85rem;
    color: #777;
  }

  /* Hero card */
  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .hero-card {
    background: #fff;
    border-radius: 20px;
    padding: 36px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(0, 0, 0, 0.04);
    width: 100%;
    max-width: 400px;
  }

  .hero-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .hero-card-icon {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, #6c63ff, #9f7aea);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .hero-card-title {
    font-weight: 700;
    font-size: 1rem;
    color: #1a1a2e;
  }

  .hero-card-sub {
    font-size: 0.8rem;
    color: #999;
  }

  .automation-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid #f0f0f0;
    font-size: 0.9rem;
    color: #333;
    font-weight: 500;
  }

  .automation-item:last-child {
    border-bottom: none;
  }

  .check {
    width: 26px;
    height: 26px;
    background: #e8ffe8;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .time-saved {
    margin-left: auto;
    font-size: 0.75rem;
    color: #6c63ff;
    font-weight: 600;
    background: rgba(108, 99, 255, 0.08);
    padding: 4px 10px;
    border-radius: 6px;
    white-space: nowrap;
  }

  /* ===== SERVICES ===== */
  .services {
    padding: 100px 0;
    background: #1a1a2e;
    color: #fff;
  }

  .services .section-label {
    color: #9f7aea;
  }

  .services .section-title {
    color: #fff;
  }

  .services .section-subtitle {
    color: rgba(255, 255, 255, 0.6);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .service-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 18px;
    padding: 32px 28px;
    transition: all 0.3s;
  }

  .service-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(108, 99, 255, 0.3);
    transform: translateY(-4px);
  }

  .service-icon {
    font-size: 1.75rem;
    margin-bottom: 16px;
  }

  .service-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: #fff;
  }

  .service-card p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
  }

  /* ===== HOW IT WORKS ===== */
  .how-it-works {
    padding: 100px 0;
    background: #fafafa;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    max-width: 800px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 16px;
    padding: 28px;
    transition: all 0.3s;
  }

  .step:hover {
    border-color: #e0deff;
    box-shadow: 0 8px 30px rgba(108, 99, 255, 0.08);
  }

  .step-number {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, #6c63ff, #9f7aea);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .step-content h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .step-content p {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.6;
  }

  /* ===== ABOUT ===== */
  .about {
    padding: 100px 0;
  }

  .about .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .about-text .section-label {
    margin-bottom: 12px;
  }

  .about-text .section-title {
    margin-bottom: 20px;
  }

  .about-text p {
    font-size: 1rem;
    color: #555;
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .about-values {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 32px;
  }

  .value {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 20px;
    background: #f9f9fb;
    border-radius: 14px;
    border: 1px solid #eee;
  }

  .value-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
  }

  .value strong {
    display: block;
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .value p {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 0;
    line-height: 1.5;
  }

  .about-quote {
    background: linear-gradient(135deg, #6c63ff, #9f7aea);
    border-radius: 24px;
    padding: 48px;
    color: #fff;
  }

  .about-quote blockquote {
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: 24px;
    font-style: normal;
  }

  .about-quote cite {
    font-size: 0.9rem;
    opacity: 0.8;
    font-style: normal;
  }

  /* ===== CTA ===== */
  .cta {
    background: linear-gradient(165deg, #6c63ff 0%, #5a52d5 100%);
    color: #fff;
    text-align: center;
    padding: 100px 0;
    position: relative;
    overflow: hidden;
  }

  .cta::before {
    content: '';
    position: absolute;
    top: -100px;
    left: -100px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
    border-radius: 50%;
  }

  .cta .container {
    position: relative;
    z-index: 1;
  }

  .cta h2 {
    font-size: 2.75rem;
    font-weight: 800;
    margin-bottom: 20px;
    line-height: 1.15;
  }

  .cta > .container > p {
    font-size: 1.15rem;
    opacity: 0.85;
    margin-bottom: 40px;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .cta-note {
    margin-top: 20px;
    font-size: 0.85rem;
    opacity: 0.6;
  }

  /* ===== FOOTER ===== */
  .footer {
    background: #0d0d1a;
    color: rgba(255, 255, 255, 0.5);
    padding: 60px 0 30px;
  }

  .footer .logo {
    color: #fff;
  }

  .footer .logo span {
    color: #9f7aea;
  }

  .tagline {
    font-size: 0.9rem;
    margin-top: 8px;
    color: rgba(255, 255, 255, 0.4);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
  }

  .footer-links {
    display: flex;
    gap: 32px;
  }

  .footer-links a {
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #6c63ff;
  }

  .footer-bottom {
