  /* Message animation — 14s loop */
  .msg-1 { animation: m1 14s ease-out infinite; }
  .typing-1 { animation: t1 14s ease-out infinite; }
  .msg-2 { animation: m2 14s ease-out infinite; }
  .msg-3 { animation: m3 14s ease-out infinite; }
